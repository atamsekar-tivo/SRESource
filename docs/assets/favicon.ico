<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 64 64">
  <!-- Background -->
  <rect width="64" height="64" fill="#4F46E5"/>
  
  <!-- Main icon -->
  <g transform="translate(32, 32)">
    <!-- S shape representing SRE -->
    <path d="M -8 -12 Q -12 -9 -8 -6 Q -4 -3 -8 0 Q -12 3 -8 6 Q -4 9 -8 12" 
          fill="none" stroke="white" stroke-width="2" stroke-linecap="round"/>
    
    <!-- Wrench symbol representing DevOps/Operations -->
    <g transform="translate(10, 0)">
      <circle cx="0" cy="0" r="5" fill="white"/>
      <line x1="5" y1="-5" x2="12" y2="-12" stroke="white" stroke-width="2" stroke-linecap="round"/>
    </g>
    
    <!-- Outer dots -->
    <circle cx="0" cy="-20" r="2" fill="white"/>
    <circle cx="17" cy="-10" r="2" fill="white"/>
    <circle cx="17" cy="10" r="2" fill="white"/>
    <circle cx="0" cy="20" r="2" fill="white"/>
    <circle cx="-17" cy="10" r="2" fill="white"/>
    <circle cx="-17" cy="-10" r="2" fill="white"/>
  </g>
</svg>
